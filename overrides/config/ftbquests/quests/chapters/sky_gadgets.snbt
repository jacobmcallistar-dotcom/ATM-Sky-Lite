			title: "&bThe Melter"
			x: -8.0d
			y: 1.5d
		}
		{
			dependencies: ["41C1000000000002"]
			description: ["The &eSprinkler&r ticks crops in a wide radius using a little water and power. Your farms grow while you are three dimensions away."]
